# Server
PORT=4000

# Supabase (isi dengan value asli dari dashboard Supabase kamu)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS - URL frontend kamu (gunakan URL Vercel setelah deploy)
FRONTEND_URL=http://localhost:5173

# Kunci enkripsi untuk API keys merchant (WAJIB sama dengan yang di database)
ENCRYPTION_KEY=GANTI_DENGAN_KUNCI_RAHASIA_KAMU
